# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend domain(s))
ALLOWED_ORIGINS=https://fractalx.org

# ── Notifications (configure at least one) ────────────────────────────────────

# Option 1 — Discord or Slack incoming webhook URL
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# Slack:   api.slack.com/messaging/webhooks
WEBHOOK_URL=

# Option 2 — Resend email (https://resend.com — free tier: 3,000 emails/month)
# Create an API key at resend.com/api-keys
RESEND_API_KEY=
# Email address to receive notifications
NOTIFICATION_EMAIL=team@fractalx.org
# Sender address (must be a verified domain in Resend)
RESEND_FROM=FractalX <noreply@fractalx.org>
